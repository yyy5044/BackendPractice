package com.ssafy.live.controller;

import java.io.IOException;

import com.ssafy.live.service.GuguService;

import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

/**
 * Servlet implementation class MainServlet
 */
@WebServlet("/main")
public class MainServlet extends HttpServlet implements ControllerHelper {
	private static final long serialVersionUID = 1L;

	/**
	 * @see HttpServlet#doGet(HttpServletRequest request, HttpServletResponse response)
	 */
	protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		String action = preProcessing(request, response);
		switch(action) {
		case "guguform" -> guguform(request, response);
		case "gugu" -> gugu(request, response);
		}
	}

	/**
	 * @see HttpServlet#doPost(HttpServletRequest request, HttpServletResponse response)
	 */
	protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		String action = preProcessing(request, response);
		switch(action) {
		case "write" -> write(request, response);
		}
	}
	
	protected void write(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		
	}
	
	protected void guguform(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		String html = """
					<form action="/BE_02/main">
		<input type="hidden" value="gugu" name='action'>
		<input type="number" name="dan">
		<button>조회</button>
	</form>
				""";
		responseHtml("구구단을 외자", html, response);
	}
	
	protected void gugu(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		try {
			// 1. 파라미터 처리
			int dan = Integer.parseInt(request.getParameter("dan"));
			
			// 2. 비니지스 로직 처리
			GuguService service = new GuguService();
			String result = service.gugu(dan);
			
			// 3. 응답 처리
			responseHtml("요청 결과", result, response);
		} catch (Exception e) {
			e.printStackTrace();
			responseHtml("오류", "단이 잘못됨" + e.getMessage(), response);
		}
	}
	
	protected void template(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		
	}

}
